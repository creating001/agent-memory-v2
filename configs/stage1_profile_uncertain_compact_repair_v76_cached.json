{
  "name": "stage1_profile_uncertain_compact_repair_v76_cached",
  "description": "V76 query-side ablation on top of v75/v73: keep build memory, retrieval, compiler evidence context, answer model, compact repair prompt, and mechanical finalizer policy unchanged, but restrict profile_preference repair to drafts with generic prediction-time uncertainty or missing-evidence signals. This tests whether the v75 controlled positive signal comes from repairing refusals rather than rewriting already supported personalized answers. It is inspired by creating001's two-stage evidence-to-answer query design, SimpleMem's adequacy/reflection pass, xMemory's multi-view retrieval discipline, and method.md's profile/event memory direction. It uses only question text, visible question_time, raw dialogue, retrieved Memory Context, route, draft answer, and draft JSON; no gold answer, judge output, benchmark label, sample id, qid, row index, test feedback, or sample-level rules.",
  "build_memory": {
    "enabled": true,
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0,
    "max_tokens": 2048,
    "timeout": 240,
    "max_turns_per_chunk": 80,
    "max_chars_per_turn": 500,
    "max_records_per_chunk": 20,
    "top_k": 20,
    "max_sources_per_record": 4,
    "drop_query_stopwords": true,
    "include_superseded": false,
    "include_superseded_information_needs": [
      "temporal_lookup",
      "list_count"
    ],
    "cache": {
      "enabled": true,
      "path": "outputs/cache/qwen3_build_memory.sqlite",
      "namespace": "stage1_agent_memory_v1_qwen3_30b_cold"
    }
  },
  "retrieval": {
