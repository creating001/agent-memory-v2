{
  "name": "stage1_route_priority_v6_cached",
  "description": "Query-side v6 ablation reusing the v4 build cache: v4 plus generic information-need priority so explicit temporal/duration questions route before recent/current mentions.",
  "build_memory": {
    "enabled": true,
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0.0,
    "max_tokens": 2048,
    "timeout": 120.0,
    "max_turns_per_chunk": 80,
    "max_chars_per_turn": 500,
    "max_records_per_chunk": 20,
    "top_k": 20,
    "max_sources_per_record": 4,
    "drop_query_stopwords": true,
    "include_superseded": false,
    "cache": {
      "enabled": true,
      "path": "outputs/cache/qwen3_build_memory.sqlite",
      "namespace": "stage1_agent_memory_v1_qwen3_30b_cold"
    }
  },
  "retrieval": {
    "top_k": 12,
    "max_top_k": 36,
    "neighbor_window": 1,
    "neighbor_order": "hit_priority",
    "drop_query_stopwords": true,
    "score_threshold": 0.0,
    "dense": {
      "enabled": true,
      "base_url": "http://127.0.0.1:8001/v1",
      "model": "Qwen/Qwen3-Embedding-0.6B",
      "top_k": 12,
      "batch_size": 32,
      "rrf_k": 60,
      "lexical_protect_top_n": 2,
      "timeout": 120.0,
      "cache": {
        "enabled": true,
        "path": "outputs/cache/qwen3_embedding.sqlite",
        "namespace": "Qwen/Qwen3-Embedding-0.6B"
      }
    },
    "session_bm25": {
      "enabled": true,
      "top_k": 8,
      "anchor_top_k": 2,
      "max_anchor_hits": 12,
      "protect_turn_hits": 4,
      "drop_query_stopwords": true,
      "anchor_drop_query_stopwords": true,
      "score_threshold": 0.0,
      "anchor_score_threshold": 0.0,
      "enabled_route_signals": [
        "temporal",
        "recent_or_current"
      ],
      "enabled_query_patterns": [
        "\\b20\\d{2}\\b",
        "\\b(?:january|february|march|april|june|july|august|september|october|november|december)\\b",
        "\\bmay\\s+20\\d{2}\\b"
      ]
    }
  },
  "route": {
    "enable_recommendation_profile_patterns": true,
    "temporal_priority_over_recent": true
  },
  "compiler": {
    "max_evidence_items": 36,
    "max_evidence_chars": 18000,
    "max_memory_records": 16,
    "answer_style": "concise",
    "temporal_grounding": true,
    "temporal_hints": true,
    "temporal_workpad": true,
    "evidence_order": "question_overlap",
    "memory_order": "question_overlap",
    "memory_layout": "typed_sections",
    "route_guidance": true
  },
  "answer": {
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0.0,
    "max_input_tokens": 131072,
    "max_output_tokens": 16384,
    "max_tokens": 16384,
    "timeout": 120.0
  }
}
