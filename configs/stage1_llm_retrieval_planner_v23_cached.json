{
  "name": "stage1_llm_retrieval_planner_v23_cached",
  "description": "Query-side LLM retrieval planner on top of v18 hybrid BM25+dense retrieval. The planner sees only question text, question time, and clean route signals, then adds generic complementary retrieval queries for multi-entity, list/count, comparison, and current/update questions. Original-question retrieval remains protected. Inspired by SimpleMem intent-aware retrieval planning, xMemory/Hindsight multi-view retrieval, and the old external naive RAG multi-query idea, but no gold, judge, benchmark labels, sample ids, qids, row indices, or sample-level rules are used.",
  "query_planner": {
    "enabled": true,
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0,
    "max_tokens": 512,
    "timeout": 120,
    "max_queries": 4,
    "max_query_chars": 240,
    "response_format_json": false,
    "cache": {
      "enabled": true,
      "path": "outputs/cache/qwen3_query_planner.sqlite",
      "namespace": "stage1_query_planner_v1_qwen3_30b"
    }
  },
  "build_memory": {
    "enabled": true,
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0,
    "max_tokens": 2048,
    "timeout": 120,
    "max_turns_per_chunk": 80,
    "max_chars_per_turn": 500,
    "max_records_per_chunk": 20,
    "top_k": 20,
    "max_sources_per_record": 4,
    "drop_query_stopwords": true,
    "include_superseded": false,
    "include_superseded_information_needs": [
      "temporal_lookup",
      "list_count"
    ],
    "cache": {
      "enabled": true,
      "path": "outputs/cache/qwen3_build_memory.sqlite",
      "namespace": "stage1_agent_memory_v1_qwen3_30b_cold"
    }
  },
  "retrieval": {
    "top_k": 40,
    "max_top_k": 40,
    "neighbor_window": 0,
    "neighbor_order": "hit_priority",
    "drop_query_stopwords": true,
    "score_threshold": 0,
    "lexical": {
      "enabled": true
    },
    "dense": {
      "enabled": true,
      "base_url": "http://127.0.0.1:8001/v1",
      "model": "Qwen/Qwen3-Embedding-0.6B",
      "top_k": 40,
      "batch_size": 32,
      "document_text_mode": "external_naive",
      "query_text_mode": "external_naive",
      "rrf_k": 60,
      "lexical_protect_top_n": 0,
      "protect_top_n": 32,
      "timeout": 120,
      "cache": {
        "enabled": true,
        "path": "outputs/cache/qwen3_embedding.sqlite",
        "namespace": "Qwen/Qwen3-Embedding-0.6B"
      }
    },
    "session_bm25": {
      "enabled": false
    }
  },
  "route": {
    "enable_broad_list_patterns": false,
    "enable_recommendation_profile_patterns": true,
    "temporal_priority_over_recent": false
  },
  "compiler": {
    "prompt_mode": "external_naive",
    "max_evidence_items": 40,
    "max_evidence_chars": 18000,
    "max_memory_records": 0,
    "answer_style": "concise",
    "temporal_grounding": false,
    "temporal_hints": false,
    "temporal_workpad": true,
    "temporal_workpad_scope": "route",
    "temporal_workpad_max_rows": 12,
    "temporal_workpad_max_pairs": 12,
    "structured_guide": true,
    "structured_guide_max_rows": 12,
    "structured_guide_include_rows": true,
    "structured_guide_include_memory": false,
    "structured_guide_disabled_signals": [
      "personalized_recommendation"
    ],
    "evidence_order": "retrieval",
    "memory_order": "retrieval",
    "memory_layout": "flat",
    "row_text_mode": "full",
    "route_guidance": false,
    "evidence_row_labels": false,
    "final_answer_checklist": false,
    "temporal_text_normalization": true
  },
  "answer": {
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0,
    "max_input_tokens": 131072,
    "max_output_tokens": 16384,
    "max_tokens": 16384,
    "output_format": "json_answer",
    "timeout": 120
  }
}
