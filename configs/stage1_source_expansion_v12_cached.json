{
  "name": "stage1_source_expansion_v12_cached",
  "description": "Build-to-query source expansion: keep the external-aligned clean naive RAG answer contract, enable cached build-stage typed memory only as a raw-source retrieval signal, protect the strongest dense raw evidence, and do not expose typed memory records directly to the answer prompt.",
  "build_memory": {
    "enabled": true,
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0,
    "max_tokens": 2048,
    "timeout": 120,
    "max_turns_per_chunk": 80,
    "max_chars_per_turn": 500,
    "max_records_per_chunk": 20,
    "top_k": 20,
    "max_sources_per_record": 4,
    "drop_query_stopwords": true,
    "include_superseded": false,
    "include_superseded_information_needs": [
      "temporal_lookup",
      "list_count"
    ],
    "cache": {
      "enabled": true,
      "path": "outputs/cache/qwen3_build_memory.sqlite",
      "namespace": "stage1_agent_memory_v1_qwen3_30b_cold"
    }
  },
  "retrieval": {
    "top_k": 40,
    "max_top_k": 40,
    "neighbor_window": 0,
    "neighbor_order": "hit_priority",
    "drop_query_stopwords": false,
    "score_threshold": 0,
    "lexical": {
      "enabled": false
    },
    "dense": {
      "enabled": true,
      "base_url": "http://127.0.0.1:8001/v1",
      "model": "Qwen/Qwen3-Embedding-0.6B",
      "top_k": 40,
      "batch_size": 32,
      "document_text_mode": "external_naive",
      "query_text_mode": "external_naive",
      "rrf_k": 60,
      "lexical_protect_top_n": 0,
      "protect_top_n": 32,
      "timeout": 120,
      "cache": {
        "enabled": true,
        "path": "outputs/cache/qwen3_embedding.sqlite",
        "namespace": "Qwen/Qwen3-Embedding-0.6B"
      }
    }
  },
  "route": {
    "enable_broad_list_patterns": false,
    "enable_recommendation_profile_patterns": false,
    "temporal_priority_over_recent": false
  },
  "compiler": {
    "prompt_mode": "external_naive",
    "max_evidence_items": 40,
    "max_evidence_chars": 18000,
    "max_memory_records": 0,
    "answer_style": "concise",
    "temporal_grounding": false,
    "temporal_hints": false,
    "temporal_workpad": false,
    "evidence_order": "retrieval",
    "memory_order": "retrieval",
    "memory_layout": "flat",
    "row_text_mode": "full",
    "route_guidance": false,
    "evidence_row_labels": false,
    "final_answer_checklist": false
  },
  "answer": {
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0,
    "max_input_tokens": 131072,
    "max_output_tokens": 16384,
    "max_tokens": 16384,
    "output_format": "json_answer",
    "timeout": 120
  }
}
