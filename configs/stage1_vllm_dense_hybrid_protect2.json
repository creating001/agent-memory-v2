{
  "name": "stage1_vllm_dense_hybrid_protect2",
  "description": "Stage-1 vLLM answerer with BM25 + dense retrieval, RRF fusion, and lexical top-2 nucleus protection.",
  "inherits": "stage1_vllm_dense_hybrid",
  "retrieval": {
    "top_k": 8,
    "max_top_k": 24,
    "neighbor_window": 1,
    "neighbor_order": "hit_priority",
    "drop_query_stopwords": false,
    "score_threshold": 0.0,
    "dense": {
      "enabled": true,
      "base_url": "http://127.0.0.1:8001/v1",
      "model": "Qwen/Qwen3-Embedding-0.6B",
      "top_k": 8,
      "batch_size": 32,
      "rrf_k": 60,
      "lexical_protect_top_n": 2,
      "timeout": 120.0
    }
  },
  "compiler": {
    "max_evidence_items": 20,
    "max_evidence_chars": 12000
  },
  "answer": {
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0.0,
    "max_tokens": 256,
    "timeout": 120.0
  }
}
