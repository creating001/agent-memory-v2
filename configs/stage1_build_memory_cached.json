{
  "name": "stage1_build_memory_cached",
  "description": "Stage-1 candidate with build-stage LLM typed memory, managed cache, hybrid raw retrieval, typed-memory retrieval, and route guidance.",
  "build_memory": {
    "enabled": true,
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0.0,
    "max_tokens": 768,
    "timeout": 120.0,
    "max_turns_per_chunk": 80,
    "max_chars_per_turn": 500,
    "max_records_per_chunk": 16,
    "top_k": 16,
    "max_sources_per_record": 3,
    "drop_query_stopwords": true,
    "include_superseded": false,
    "cache": {
      "enabled": true,
      "path": "outputs/cache/qwen3_build_memory.sqlite",
      "namespace": "stage1_build_memory_v2_qwen3_30b_parallel"
    }
  },
  "retrieval": {
    "top_k": 12,
    "max_top_k": 36,
    "neighbor_window": 1,
    "neighbor_order": "hit_priority",
    "drop_query_stopwords": false,
    "score_threshold": 0.0,
    "dense": {
      "enabled": true,
      "base_url": "http://127.0.0.1:8001/v1",
      "model": "Qwen/Qwen3-Embedding-0.6B",
      "top_k": 12,
      "batch_size": 32,
      "rrf_k": 60,
      "lexical_protect_top_n": 2,
      "timeout": 120.0,
      "cache": {
        "enabled": true,
        "path": "outputs/cache/qwen3_embedding.sqlite",
        "namespace": "Qwen/Qwen3-Embedding-0.6B"
      }
    },
    "session_bm25": {
      "enabled": true,
      "top_k": 8,
      "anchor_top_k": 2,
      "max_anchor_hits": 12,
      "protect_turn_hits": 4,
      "drop_query_stopwords": true,
      "anchor_drop_query_stopwords": true,
      "score_threshold": 0.0,
      "anchor_score_threshold": 0.0,
      "enabled_route_signals": [
        "temporal",
        "recent_or_current"
      ],
      "enabled_query_patterns": [
        "\\b20\\d{2}\\b",
        "\\b(?:january|february|march|april|june|july|august|september|october|november|december)\\b",
        "\\bmay\\s+20\\d{2}\\b"
      ]
    }
  },
  "compiler": {
    "max_evidence_items": 36,
    "max_evidence_chars": 18000,
    "max_memory_records": 12,
    "answer_style": "concise",
    "temporal_grounding": true,
    "route_guidance": true
  },
  "answer": {
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0.0,
    "max_tokens": 128,
    "timeout": 120.0
  }
