{
  "name": "stage1_structured_answer_contract_v26_cached",
  "description": "Query-side answer/compiler ablation on top of v18 and v25: keep the same route-scoped structured answer contract for list_count and temporal_lookup, but disable risky count finalization after v25 LME full showed count corrections were mostly harmful. Only narrow money-sum mechanical finalization remains enabled. Prompt, build, retrieval, and answer cache namespace stay identical to v25, so this isolates finalizer policy while preserving logical token accounting. Clean generic method; no gold, judge, benchmark labels, sample ids, qids, row indices, or sample-level rules are used.",
  "build_memory": {
    "enabled": true,
    "mode": "openai_compatible",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0,
    "max_tokens": 2048,
    "timeout": 120,
    "max_turns_per_chunk": 80,
    "max_chars_per_turn": 500,
    "max_records_per_chunk": 20,
    "top_k": 20,
    "max_sources_per_record": 4,
    "drop_query_stopwords": true,
    "include_superseded": false,
    "include_superseded_information_needs": [
      "temporal_lookup",
      "list_count"
    ],
    "cache": {
      "enabled": true,
      "path": "outputs/cache/qwen3_build_memory.sqlite",
      "namespace": "stage1_agent_memory_v1_qwen3_30b_cold"
    }
  },
  "retrieval": {
    "top_k": 40,
    "max_top_k": 40,
    "neighbor_window": 0,
    "neighbor_order": "hit_priority",
    "drop_query_stopwords": true,
    "score_threshold": 0,
    "lexical": {
      "enabled": true
    },
    "dense": {
      "enabled": true,
      "base_url": "http://127.0.0.1:8001/v1",
      "model": "Qwen/Qwen3-Embedding-0.6B",
      "top_k": 40,
      "batch_size": 32,
      "document_text_mode": "external_naive",
      "query_text_mode": "external_naive",
      "rrf_k": 60,
      "lexical_protect_top_n": 0,
      "protect_top_n": 32,
      "timeout": 120,
      "cache": {
        "enabled": true,
        "path": "outputs/cache/qwen3_embedding.sqlite",
        "namespace": "Qwen/Qwen3-Embedding-0.6B"
      }
    },
    "session_bm25": {
      "enabled": false
    }
  },
  "route": {
    "enable_broad_list_patterns": false,
    "enable_recommendation_profile_patterns": true,
    "temporal_priority_over_recent": false
  },
  "compiler": {
    "prompt_mode": "external_naive",
    "max_evidence_items": 40,
    "max_evidence_chars": 18000,
    "max_memory_records": 0,
    "answer_style": "concise",
    "temporal_grounding": false,
    "temporal_hints": false,
    "temporal_workpad": true,
    "temporal_workpad_scope": "route",
    "temporal_workpad_max_rows": 12,
    "temporal_workpad_max_pairs": 12,
    "structured_guide": true,
    "structured_guide_max_rows": 12,
    "structured_guide_include_rows": true,
    "structured_guide_include_memory": false,
    "structured_guide_disabled_signals": [
      "personalized_recommendation"
    ],
    "structured_answer_contract": true,
    "structured_answer_contract_information_needs": [
      "list_count",
      "temporal_lookup"
