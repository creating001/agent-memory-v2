    "base_url": "http://127.0.0.1:8000/v1",
    "model": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "temperature": 0,
    "max_input_tokens": 131072,
    "max_output_tokens": 16384,
    "max_tokens": 16384,
    "output_format": "json_answer",
    "timeout": 120,
    "cache": {
      "enabled": true,
      "path": "outputs/cache/qwen3_answer_v25.sqlite",
      "namespace": "stage1_structured_answer_contract_v25_qwen3_30b"
